{
  "compilerOptions": {
    "target": "ES2022",

    "module": "CommonJS",
    "moduleResolution": "Node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,
    "jsx": "react-jsx"
  },

  "include": ["src"]
}